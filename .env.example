# Copy this file to .env only if you want to use PostgreSQL locally
SECRET_KEY=django-insecure-change-this-to-a-real-secret-key-in-production
DEBUG=True

# Optional PostgreSQL Database Settings
# Change DB_PORT if your PostgreSQL server runs on a custom port such as 5000.
DB_NAME=medicinedbfile
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5000
